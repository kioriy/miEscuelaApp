APP_NAME=miEscuelaApp
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.miescuela.net

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=miEscuela
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=app.miescuela.net

CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=mail.miescuela.net
MAIL_PORT=465
MAIL_USERNAME=hola@miescuela.net
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="hola@miescuela.net"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=https://app.miescuela.net/api
VITE_GOOGLE_CLIENT_ID=
